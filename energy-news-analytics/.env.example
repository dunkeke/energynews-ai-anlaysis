# 能源化工新闻分析系统 - 环境变量配置

# 应用配置
APP_NAME=能源化工新闻分析系统
APP_VERSION=1.0.0
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://energy_user:energy_password@localhost:5432/energy_news
MONGODB_URL=mongodb://admin:password@localhost:27017/energy_news?authSource=admin
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# 安全配置
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API配置
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# 采集配置
CRAWL_INTERVAL_MINUTES=15
MAX_CRAWL_WORKERS=5

# NLP配置
NLP_MODEL_PATH=./nlp-models
SENTIMENT_MODEL=uer/roberta-base-finetuned-jd-binary-chinese

# 量化配置
SCORE_CALCULATION_INTERVAL=5
HISTORICAL_DATA_DAYS=90

# 预警配置
ALERT_CHECK_INTERVAL=1

# 外部API密钥（可选）
BLOOMBERG_API_KEY=
REUTERS_API_KEY=
PLATTS_API_KEY=
EIA_API_KEY=
