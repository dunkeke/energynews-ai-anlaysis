FROM registry.cn-hangzhou.aliyuncs.com/library/node:18-alpine

WORKDIR /app

# 复制package.json
COPY frontend/package.json .

# 安装依赖
RUN npm install

# 复制应用代码
COPY frontend/ .

# 构建应用
RUN npm run build

# 使用nginx提供静态文件
FROM nginx:alpine

# 复制构建结果
COPY --from=0 /app/build /usr/share/nginx/html

# 复制nginx配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 暴露端口
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
